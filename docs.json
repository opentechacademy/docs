{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Mintlify Starter Kit",
  "colors": {
    "primary": "#f5c453",
    "light": "#f5c453",
    "dark": "#f5c453"
  },
  "favicon": {
    "light": "https://opentechacademy.org/favicon.ico",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://opentechacademy.org"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@opentechacademy.org"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/opentechacademy",
      "website": "https://opentechacademy.org",
      "youtube": "https://youtube.com/theopentechacademy"
    }
  },
  "errors": {
    "404": {
      "redirect": false
    }
  },
  "seo": {
    "indexing": "all"
  },
  "background": {
    "color": {
      "light": "#02060d",
      "dark": "#02060d"
    },
    "image": {
      "light": "/images/opentechacademybackground.png",
      "dark": "/images/opentechacademybackground.png"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "thumbnails": {
    "background": "/images/opentechacademybackground.png"
  },
  "metadata": {
    "timestamp": true
  }
}
